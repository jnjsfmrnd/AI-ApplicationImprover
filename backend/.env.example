# GitHub Personal Access Token with 'models: read' scope
# Create at: https://github.com/settings/tokens  (classic or fine-grained, add Models permission)
GITHUB_TOKEN=ghp_...

# GitHub Models — available model names: gpt-4o-mini, gpt-4o, Phi-3.5-mini-instruct
LLM_PROVIDER=auto
LLM_MODEL=gpt-4o-mini

# Gemini (optional). Set LLM_PROVIDER=gemini to force Gemini usage.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Azure OpenAI (optional). If GitHub Models is not configured, backend can use this path.
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-10-21

# Leave as sqlite for local dev (no Postgres needed); set Postgres URL for production
DATABASE_URL=sqlite:///./ai_application_improver.db

# Comma-separated allowed CORS origins; use * to allow all (dev only)
# ALLOWED_ORIGINS=https://<your-static-webapp>.azurestaticapps.net
